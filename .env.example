POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_MASTER_COLLECTION=master_orders
POCKETBASE_UPLOAD_LOG_COLLECTION=upload_log
POCKETBASE_PAGE_SIZE=200

# One of these approaches works:
# 1) create an admin token in the PocketBase UI and set POCKETBASE_API_TOKEN
# 2) set email/password and let the app/script authenticate directly
POCKETBASE_ADMIN_EMAIL=admin@local.test
POCKETBASE_ADMIN_PASSWORD=Admin1234!
POCKETBASE_ADMIN_TOKEN=
POCKETBASE_API_TOKEN=

# Rotate token when it expires:
#   python scripts/refresh_pocketbase_token.py
